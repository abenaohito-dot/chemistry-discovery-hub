# Chemistry Discovery Hub — Environment Variables
# Copy this file to .env and fill in your values

# NCBI API Key (optional but recommended: increases rate limit from 3→10 req/s)
# Get yours free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# CrossRef Polite Pool (optional: add your email for priority queue)
CROSSREF_EMAIL=your.email@institution.ac.jp
